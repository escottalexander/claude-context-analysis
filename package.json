{
  "name": "ccexplorer",
  "version": "0.1.2",
  "description": "Browser-based explorer for Claude Code sessions.",
  "author": "Elliott Alexander <escottalexander@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/escottalexander/ccexplorer"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "ccexplorer": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "copy:assets": "node scripts/copy-assets.mjs",
    "prepack": "npm run build && npm run copy:assets",
    "start": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
